{
  "name": "@benhigham/javascript",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^22.13.0 || >=24"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24"
    }
  },
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "prepare": "lefthook install || echo 'lefthook install failed'",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "lint:affected": "turbo run lint --affected",
    "lint:fix": "turbo run lint:fix",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.md\"",
    "lint:actions": "actionlint",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "release": "changeset publish",
    "version": "changeset version",
    "skills:add": "npx skills add",
    "skills:remove": "npx skills remove",
    "skills:update": "npx skills update",
    "skills:list": "npx skills list"
  },
  "devDependencies": {
    "@benhigham/commitlint-config": "workspace:*",
    "@benhigham/prettier-config": "workspace:*",
    "@changesets/changelog-github": "catalog:",
    "@changesets/cli": "catalog:",
    "@commitlint/cli": "catalog:",
    "eslint": "catalog:",
    "lefthook": "catalog:",
    "markdownlint-cli2": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:"
  }
}

{
  "name": "@benhigham/tsconfig",
  "version": "3.0.0",
  "description": "Shareable TypeScript configurations",
  "type": "module",
  "exports": {
    ".": "./src/node.json",
    "./node.json": "./src/node.json",
    "./browser.json": "./src/browser.json",
    "./node-app.json": "./src/node-app.json",
    "./browser-app.json": "./src/browser-app.json"
  },
  "files": [
    "src"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "keywords": [
    "tsconfig",
    "typescript",
    "ts",
    "config",
    "configuration"
  ],
  "author": "Benjamin Higham",
  "license": "MIT",
  "homepage": "https://github.com/benhigham/javascript/tree/main/packages/tsconfig#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/benhigham/javascript.git",
    "directory": "packages/tsconfig"
  },
  "bugs": {
    "url": "https://github.com/benhigham/javascript/issues"
  },
  "peerDependencies": {
    "typescript": ">=6.0"
  },
  "devDependencies": {
    "@benhigham/eslint-config": "workspace:*",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest run"
  }

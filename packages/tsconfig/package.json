{
  "name": "@benhigham/tsconfig",
  "version": "2.0.0",
  "description": "Shareable TypeScript configurations",
  "type": "module",
  "exports": {
    ".": "./src/base.json",
    "./astro.json": "./src/astro.json",
    "./browser.json": "./src/browser.json",
    "./next.json": "./src/next.json",
    "./react-app.json": "./src/react-app.json",
    "./vite.json": "./src/vite.json"
  },
  "files": [
    "src"
  ],
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "tsconfig",
    "typescript",
    "ts",
    "config",
    "configuration"
  ],
  "author": "Benjamin Higham",
  "license": "MIT",
  "homepage": "https://github.com/benhigham/javascript/tree/main/packages/tsconfig#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/benhigham/javascript.git",
    "directory": "packages/tsconfig"
  },
  "bugs": {
    "url": "https://github.com/benhigham/javascript/issues"
  },
  "peerDependencies": {
    "typescript": ">=6.0"
  },
  "devDependencies": {
    "@benhigham/eslint-config": "workspace:*",
    "eslint": "catalog:",
    "typescript": "catalog:"
  },
  "scripts": {
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  }

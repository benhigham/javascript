{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    // Browser lib tracks the standard ES-year, not the literal floor: the staged
    // ESNext.* helpers stay node-only even when individually below it. See ADR-0006.
    "lib": ["ES2024", "DOM"],
    "jsx": "react-jsx"
  }
}

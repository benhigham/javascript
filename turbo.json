{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["CI"],
  "tasks": {
    "transit": {
      "dependsOn": ["^transit"]
    },
    "lint": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "lint:fix": {
      "cache": false
    },
    "test": {
      "dependsOn": ["transit"],
      "outputs": []
    }
  }
}
